# -------------------------------------------------------
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git.
# All keys below live only in Netlify env vars in production.
# -------------------------------------------------------

# ── n8n Copywriting Webhook (async — workflow runs 35–45s) ──────────────────
# Paste your n8n Webhook node URL here.
# n8n should respond with HTTP 200 immediately (no "Respond to Webhook" node).
# When finished, n8n POSTs the result to /.netlify/functions/copy-callback.
# The dashboard polls every 2s until the result arrives (up to 3 min).
N8N_COPY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/generate-email-copy

# Netlify site URL — used to tell n8n where to POST the callback result
# Set automatically in Netlify deploys. For local dev, set to your ngrok/tunnel URL.
URL=https://your-site.netlify.app

# GoHighLevel
GHL_API_KEY=...
# Agency-level API key — used to switch between sub-accounts

# Google APIs (Drive image picker)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
# Service account JSON (alternative to OAuth tokens)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Chat webhook (for approval notifications)
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...

# App config
VITE_APP_TITLE="Email Production Studio"
